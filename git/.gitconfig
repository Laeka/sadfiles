[user]
  name = Laeka
  email = ale.tct16@gmail.com

[credential]
  helper = libsecret

[core]
  editor = nvim
  autocrlf = input
  excludesfile = /home/laekagg/.gitignore_global
  pager = delta

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true

[merge]
  conflictstyle = diff3

[diff]
  colorMoved = default

[alias]
  co = checkout
  ci = commit -m
  st = status
  br = branch
  hist = log --pretty=format:\"%h %af | %s%d [%an]\" --graph --date=short
  d = diff
  pl = pull
  pu = push
  a = add
  ap = add -p
  ac = !git add . && git commit -m
  undo = reset --soft HEAD-1
  cp = cherry-pick
  cl = clone

[color]
  ui = true

[color "diff-highlight"]
  oldNormal = red bold
  oldHighlight = red bold 52
  newNormal = green bold
  newHighlight = green bold 52

[color "diff"]
  meta = yellow
  frag = magenta bold
  commit = yellow bold
  old = red bold
  new = green bold
  whitespace = red reverse

[init]
  defaultBranch = main
